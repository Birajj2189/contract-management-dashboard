# ─────────────────────────────────────────────────────────────────────────────
# Contract Management — Frontend Environment Variables
# Copy this file to .env and fill in the values.
# All variables must be prefixed with VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ──────────────────────────────────────────────────────────────────────
# Backend base URL (no trailing slash).
# The Vite dev server proxies /api/* to this origin automatically.
VITE_API_URL=http://localhost:5001

# ── Dev Server ───────────────────────────────────────────────────────────────
# Port the Vite dev server listens on.
VITE_PORT=5173

# ── App Meta ─────────────────────────────────────────────────────────────────
# Displayed in the browser tab and login screen.
VITE_APP_NAME=Contract Management

# ── React Query ──────────────────────────────────────────────────────────────
# How long (ms) fetched data is considered fresh before a background refetch.
# Default: 5 minutes = 300000
VITE_QUERY_STALE_TIME=300000

# Number of times a failed query is retried before showing an error.
VITE_QUERY_RETRY=1

# ── UI / UX ───────────────────────────────────────────────────────────────────
# How long (ms) toast notifications stay visible.
VITE_TOAST_DURATION=4000

# Debounce delay (ms) applied to search inputs before firing an API call.
VITE_DEBOUNCE_DELAY=400

# ── Pagination ────────────────────────────────────────────────────────────────
# Default number of rows per page in contract tables.
VITE_PAGE_SIZE=10

# Upper limit when loading full lists for client-side pages (parties, reports, dashboard).
VITE_MAX_LIST_LIMIT=500
