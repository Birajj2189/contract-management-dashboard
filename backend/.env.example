NODE_ENV=development
PORT=5000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://contract_user:contract_pass@localhost:5432/contract_db

# JWT secrets — use long, random strings (min 32 chars each)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token expiry durations (access token short, refresh token long)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:5173

# bcrypt work factor (10–14 recommended; higher = slower but more secure)
BCRYPT_ROUNDS=12

# Rate limiting for auth endpoints (register, login)
# RATE_LIMIT_WINDOW_MS: window in milliseconds (default: 15 minutes = 900000)
# RATE_LIMIT_MAX: max requests per window per IP (default: 20)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
